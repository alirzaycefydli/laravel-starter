includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    paths:
        - app
        - bootstrap/app.php
        - config
        - database
        - public
        - routes

    level: 6
    tmpDir: /tmp/phpstan

