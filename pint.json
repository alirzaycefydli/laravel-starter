{
    "preset": "laravel",
    "notPath": [
        "tests/TestCase.php"
    ],
    "rules": {
        "declare_strict_types": true,
        "final_class": true,
        "date_time_immutable": true,
        "strict_comparison": true,
        "visibility_required": true,
        "protected_to_private": true,
        "ordered_class_elements": true,
        "ordered_interfaces": true,
        "ordered_traits": true
    }
}
